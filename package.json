{
  "name": "metagraphed",
  "version": "0.1.0-beta.0",
  "private": true,
  "type": "module",
  "description": "Operational metadata, health, schemas, and public interface discovery for Bittensor subnets.",
  "homepage": "https://metagraph.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSONbored/metagraphed.git"
  },
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.23.1"
  },
  "workspaces": [
    "apps/ui",
    "packages/client",
    "packages/contract",
    "packages/ui-kit"
  ],
  "scripts": {
    "validate": "node scripts/validate.ts",
    "build": "node scripts/build.ts",
    "build:artifacts": "node scripts/build-artifacts.ts",
    "pipeline:check": "node scripts/pipeline.ts --check",
    "pipeline:refresh": "node scripts/pipeline.ts --refresh",
    "artifacts:prepare-local": "node scripts/prepare-local-r2-staging.ts",
    "sync:subnets": "node scripts/sync-subnets.ts --write",
    "sync:subnets:dry-run": "node scripts/sync-subnets.ts --dry-run",
    "discover:candidates": "node scripts/discover-candidates.ts --write",
    "discover:candidates:dry-run": "node scripts/discover-candidates.ts --dry-run",
    "discover:testnet": "node scripts/discover-testnet-surfaces.ts",
    "verify:candidates": "node scripts/verify-candidates.ts --write",
    "verify:candidates:dry-run": "node scripts/verify-candidates.ts --dry-run",
    "curate:baseline": "node scripts/curate-baseline.ts --write",
    "curate:baseline:dry-run": "node scripts/curate-baseline.ts --dry-run",
    "review:promote": "node scripts/promote-reviewed.ts --write",
    "review:promote:dry-run": "node scripts/promote-reviewed.ts --dry-run",
    "review:queue": "node scripts/review-queue.ts --write",
    "review:queue:dry-run": "node scripts/review-queue.ts --dry-run",
    "economics:refresh": "node scripts/refresh-economics.ts --write",
    "economics:refresh:dry-run": "node scripts/refresh-economics.ts --dry-run",
    "schemas:snapshot": "node scripts/snapshot-openapi.ts --write",
    "schemas:snapshot:dry-run": "node scripts/snapshot-openapi.ts --dry-run",
    "capture:fixtures": "node scripts/capture-fixtures.ts --write",
    "capture:fixtures:dry-run": "node scripts/capture-fixtures.ts --dry-run",
    "schemas:bundle": "node scripts/bundle-schemas.ts --write",
    "schemas:bundle:check": "node scripts/bundle-schemas.ts",
    "adapters:snapshot": "node scripts/snapshot-adapters.ts --write",
    "adapters:snapshot:dry-run": "node scripts/snapshot-adapters.ts --dry-run",
    "probes:smoke": "node scripts/probes-smoke.ts",
    "sync:summary": "node scripts/sync-summary.ts",
    "scan:public-safety": "node scripts/scan-public-safety.ts",
    "validate:schemas": "node scripts/validate-schemas.ts",
    "validate:api": "node scripts/validate-api.ts",
    "validate:committed-seed": "node scripts/validate-committed-seed.ts",
    "validate:mcp": "node scripts/validate-mcp.ts",
    "validate:ai": "node scripts/validate-ai-routes.ts",
    "validate:openapi": "node scripts/validate-openapi.ts",
    "validate:types": "node scripts/validate-types.ts",
    "validate:contract-drift": "node scripts/validate-contract-drift.ts",
    "validate:schema-enums": "node scripts/validate-schema-enums.ts",
    "validate:openapi-examples": "node scripts/validate-openapi-examples.ts",
    "validate:generated-client": "node scripts/validate-generated-client.ts",
    "validate:client-sdk-sync": "node scripts/validate-client-sdk-sync.ts",
    "contract:summary": "node scripts/contract-change-summary.ts",
    "validate:artifact-budgets": "node scripts/validate-artifact-budgets.ts",
    "validate:docs": "node scripts/validate-docs.ts",
    "validate:readme-catalog": "node scripts/generate-registry-readme-section.ts --check",
    "readme:catalog": "node scripts/generate-registry-readme-section.ts",
    "validate:adapters": "node scripts/validate-adapters.ts",
    "assert:probe-health": "node scripts/assert-published-probe-health.ts",
    "validate:intake": "node scripts/validate-intake.ts",
    "validate:private-boundary": "node scripts/validate-private-boundary.ts",
    "validate:workflows": "node scripts/validate-workflows.ts",
    "validate:migrations": "node scripts/validate-migrations.ts",
    "migrate": "node scripts/apply-migrations.ts",
    "migrate:dry-run": "node scripts/apply-migrations.ts --dry-run",
    "openapi:generate": "node scripts/generate-openapi.ts --write",
    "openapi:generate:dry-run": "node scripts/generate-openapi.ts",
    "types:generate": "node scripts/generate-types.ts",
    "surface:add": "node scripts/surface-add.ts",
    "subnet:new": "node scripts/subnet-new.ts",
    "enrich:issues": "node scripts/enrichment-issues.ts --write",
    "enrich:issues:dry-run": "node scripts/enrichment-issues.ts --dry-run",
    "validate:surface": "node scripts/validate-surface.ts",
    "providers:list": "node scripts/list-providers.ts",
    "r2:manifest": "node scripts/r2-manifest.ts --write",
    "r2:manifest:dry-run": "node scripts/r2-manifest.ts",
    "build-summary:refresh": "node scripts/refresh-build-summary.ts",
    "r2:download:dry-run": "node scripts/r2-download.ts",
    "r2:download": "node scripts/r2-download.ts --write",
    "r2:upload:dry-run": "node scripts/r2-upload.ts --dry-run",
    "r2:upload": "node scripts/r2-upload.ts --write",
    "changelog:publish": "node scripts/build-changelog.ts",
    "changelog:publish:dry-run": "node scripts/build-changelog.ts --dry-run",
    "surface-aliases:publish": "node scripts/build-surface-aliases.ts",
    "surface-aliases:publish:dry-run": "node scripts/build-surface-aliases.ts --dry-run",
    "kv:publish:dry-run": "node scripts/kv-publish-pointer.ts --dry-run",
    "kv:publish": "node scripts/kv-publish-pointer.ts --write",
    "webhooks:dispatch:dry-run": "node scripts/dispatch-webhooks.ts --dry-run",
    "webhooks:dispatch": "node scripts/dispatch-webhooks.ts --write",
    "cloudflare:verify:dry-run": "node scripts/cloudflare-verify.ts",
    "worker:test": "node scripts/worker-test.ts",
    "worker:deploy:dry-run": "node scripts/worker-deploy-dry-run.ts",
    "worker:bundle:budget": "node scripts/worker-bundle-budget.ts",
    "types:workers": "wrangler types -c wrangler.jsonc workers/worker-configuration.d.ts && wrangler types -c wrangler.data.jsonc --include-runtime=false workers/data-api.worker-configuration.d.ts && wrangler types -c wrangler.registry.jsonc --include-runtime=false workers/registry-sync-api.worker-configuration.d.ts",
    "worker:check-deploy-drift": "node scripts/check-worker-deploy-drift.ts",
    "deploy:api": "scripts/deploy-worker-with-sourcemaps.sh wrangler.jsonc",
    "deploy:api:preview": "scripts/deploy-worker-with-sourcemaps.sh wrangler.jsonc --preview",
    "deploy:data-api": "scripts/deploy-worker-with-sourcemaps.sh wrangler.data.jsonc",
    "deploy:data-api:preview": "scripts/deploy-worker-with-sourcemaps.sh wrangler.data.jsonc --preview",
    "deploy:registry-sync-api": "scripts/deploy-worker-with-sourcemaps.sh wrangler.registry.jsonc",
    "deploy:registry-sync-api:preview": "scripts/deploy-worker-with-sourcemaps.sh wrangler.registry.jsonc --preview",
    "smoke:live": "node scripts/smoke-live-api.ts",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run pipeline:check && npm run validate:docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --fileParallelism --testTimeout=30000 --exclude '**/artifacts.test.{mjs,ts}' --exclude '**/discovery-artifacts.test.{mjs,ts}' --exclude '**/public-safety.test.{mjs,ts}' --exclude '**/validate-error-messages.test.{mjs,ts}' --exclude '**/refresh-build-summary.test.{mjs,ts}'",
    "test:ci:artifacts": "vitest run tests/artifacts.test tests/discovery-artifacts.test tests/public-safety.test tests/validate-error-messages.test tests/refresh-build-summary.test",
    "curation:brief": "node scripts/curation-brief.ts",
    "curation:stale-notes": "node scripts/stale-gap-notes.ts",
    "curation:identity-divergence": "node scripts/identity-field-divergence.ts",
    "endpoint:brief": "node scripts/endpoint-ops-brief.ts"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@noble/hashes": "^2.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@scure/sr25519": "^0.2.0",
    "@sentry/cloudflare": "^10.66.0",
    "@sentry/node": "^10.66.0",
    "graphql": "^17.0.2",
    "graphql-ws": "^6.1.0",
    "postgres": "^3.4.9",
    "posthog-node": "^5.44.0",
    "satori": "^0.28.0",
    "satori-html": "^0.3.2",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/cli": "^3.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wrangler": "4.111.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "js-yaml": "^4.3.0",
    "ws": "^8.21.1"
  }
}
