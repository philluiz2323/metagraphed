      "name": "Gittensor docs",
      "kind": "docs",
      "url": "https://docs.gittensor.io/",
      "provider": "gittensor",
      "auth_required": false,
      "authority": "provider-claimed",
      "public_safe": true,
      "probe": {
        "enabled": true,
        "method": "GET",
        "expect": "html"
      }
    },
    {
      "id": "gittensor-registration-docs",
      "name": "Gittensor repository registration docs",
      "kind": "docs",
      "url": "https://docs.gittensor.io/register-repository.html",
      "provider": "gittensor",
      "auth_required": false,
      "authority": "provider-claimed",
      "public_safe": true,
      "probe": {
        "enabled": true,
        "method": "GET",
        "expect": "html"
      }
    },
    {
      "id": "gittensor-hyperparameters-docs",
      "name": "Gittensor repository hyperparameters docs",
      "kind": "docs",
      "url": "https://docs.gittensor.io/repository-hyperparameters",
      "provider": "gittensor",
      "auth_required": false,
      "authority": "provider-claimed",
      "public_safe": true,
      "probe": {
        "enabled": true,
        "method": "GET",
        "expect": "html"
      }
    }
  ],
  "extensions": {
    "gittensor": {
      "tracked_dimensions": [
        "repositories",
        "bounties",
        "contributions",
        "emissions_metadata",
        "maintainer_cuts",
        "mirror_freshness",
        "public_safe_aggregates"
