{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*", "workers/**/*", "scripts/**/*", "tests/**/*"],
  "exclude": [
    "node_modules",
    "apps/ui",
    "packages/*/node_modules",
    "packages/*/dist",
    "deploy/**"
  ]
}
